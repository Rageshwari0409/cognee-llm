# Copy this file to .env and fill in your values

LLM_API_KEY=your_gemini_api_key_here
GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_URL=neo4j+s://your-instance.databases.neo4j.io
GRAPH_DATABASE_USERNAME=neo4j
GRAPH_DATABASE_PASSWORD=your_neo4j_password_here
GRAPH_DATABASE_NAME=neo4j

# Optional: point Cognee at a directory that already has ingested exercise data.
# On Streamlit Cloud, omit this — data will be stored next to app.py and
# users upload the JSON to trigger ingestion.
# For local dev where data was already ingested by the notebook, set this to
# the directory that contains .cognee_system/databases/:
# COGNEE_BASE_DIR=D:\longmemory\long-memory-rag
